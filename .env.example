# Meridian Capital — demo configuration
# Copy to .env and export, or set these in your process manager.
# Everything has a sensible default; nothing is required for a local demo.

# Server
PORT=3000
HOST=0.0.0.0
# NODE_ENV=production enables secure cookies (HTTPS-only) and view caching.
NODE_ENV=development
# Trust this many proxy hops in production (Vercel: 1). Development defaults to
# direct-client semantics.
TRUST_PROXY_HOPS=1

# Branding
BRAND_NAME=Meridian Capital

# Sessions — REQUIRED in production. Random per boot if unset in development
# (sessions reset on restart, which is fine for a demo).
# SESSION_SECRET=change-me-to-a-long-random-string

# Database (SQLite file; created on first boot). For Vercel demo deployments,
# set DB_FILE=/tmp/meridian.db and accept that data is not durable.
# DB_FILE=./data/meridian.db
# DB_FILE=/tmp/meridian.db

# Demo-mode controls
DEMO_AUTO_APPROVE_KYC=true
# Seed a rich demo dataset (admin + sample clients/positions) on first boot if
# the database has no users yet. Defaults to on for Vercel (ephemeral /tmp DB),
# off elsewhere. Set explicitly to override.
# DEMO_SEED=true

# Admin / back-office console (/admin). Any account whose email matches
# ADMIN_EMAIL is promoted to administrator automatically (on boot and at
# registration). The seed script creates this account with ADMIN_PASSWORD.
ADMIN_EMAIL=admin@meridian.demo
ADMIN_PASSWORD=Admin-Demo-2026!

# Simulated performance engine
# How often a live tick is appended to every active position (ms).
TICK_INTERVAL_MS=5000
# Days of simulated daily history seeded when a position is opened.
BACKFILL_DAYS=120
# Simulated market time runs this many times faster than wall-clock time.
# 360 → one trading day passes every 4 real minutes.
SIM_SPEED=360
