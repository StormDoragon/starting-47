# Meridian Capital — demo configuration
# Copy to .env and export, or set these in your process manager.
# Everything has a sensible default; nothing is required for a local demo.

# Server
PORT=3000
HOST=0.0.0.0
# NODE_ENV=production enables secure cookies (HTTPS-only) and view caching.
NODE_ENV=development

# Branding
BRAND_NAME=Meridian Capital

# Sessions — REQUIRED in production. Random per boot if unset (sessions reset
# on restart, which is fine for a demo).
# SESSION_SECRET=change-me-to-a-long-random-string

# Database — libSQL. Locally this is an embedded SQLite file (default below);
# for Vercel or any other host without persistent local disk, point at a
# hosted libSQL/Turso database instead:
# DB_URL=libsql://<your-db>.turso.io
# DB_AUTH_TOKEN=<turso-auth-token>
# DB_FILE=./data/meridian.db

# Simulated performance engine
# 'interval' — a long-running loop appends ticks (local dev, a VM/container).
# 'lazy'     — ticks are generated on portfolio reads + a daily cron catch-up
#              (serverless hosting, e.g. Vercel, where no loop can run).
# Defaults to 'lazy' automatically when Vercel's own VERCEL env var is set,
# 'interval' otherwise — you normally don't need to set this.
# ENGINE_MODE=interval
# How often a live tick is appended to every active position (ms).
TICK_INTERVAL_MS=5000
# Days of simulated daily history seeded when a position is opened.
BACKFILL_DAYS=120
# Simulated market time runs this many times faster than wall-clock time.
# 360 → one trading day passes every 4 real minutes.
SIM_SPEED=360
# Bearer token required on GET /api/cron/tick (Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`). Required for the cron job to work;
# the endpoint 401s without it.
# CRON_SECRET=change-me-to-a-long-random-string
