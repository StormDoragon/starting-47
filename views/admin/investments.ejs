<%- include('../partials/admin-head') %>

<div class="portal-head">
  <div>
    <span class="eyebrow">Admin console</span>
    <h1>Investments</h1>
  </div>
  <span class="pill"><span class="dot"></span><%= total.toLocaleString('en-US') %> position<%= total===1?'':'s' %></span>
</div>

<%- include('../partials/flash') %>

<!-- Totals -->
<div class="kpi-row">
  <div class="card stat">
    <div class="label">Assets under management</div>
    <div class="value"><%= money.formatCents(totals.aumCents) %></div>
    <div class="sub text-muted">current market value</div>
  </div>
  <div class="card stat">
    <div class="label">Principal invested</div>
    <div class="value"><%= money.formatCents(totals.principalCents) %></div>
    <div class="sub text-muted">active positions</div>
  </div>
  <div class="card stat">
    <div class="label">Unrealised P/L</div>
    <div class="value <%= totals.gainCents>=0?'text-up':'text-down' %>"><%= (totals.gainCents>=0?'+':'') + money.formatCents(totals.gainCents) %></div>
    <div class="sub <%= totals.gainCents>=0?'text-up':'text-down' %>"><%= money.formatPct(totals.gainPct) %></div>
  </div>
  <div class="card stat">
    <div class="label">Pools</div>
    <div class="value"><%= poolBreakdown.length %></div>
    <div class="sub text-muted">managed strategies</div>
  </div>
</div>

<!-- Per-pool cards -->
<h3 class="mt-2 mb-2">Capital by pool</h3>
<div class="grid grid-2">
  <% poolBreakdown.forEach(function(p){
       var gain = p.value_cents - p.principal_cents;
       var gainPct = p.principal_cents ? gain / p.principal_cents : 0;
       var weight = totals.aumCents ? p.value_cents / totals.aumCents : 0; %>
    <div class="card card-pad">
      <div class="flex justify-between items-center">
        <span class="legend-item"><span class="swatch" style="background:<%= p.accent %>"></span><strong><%= p.name %></strong></span>
        <span class="pill <%= gain>=0?'pill-up':'pill-down' %>"><span class="dot"></span><%= money.formatPct(gainPct) %></span>
      </div>
      <div class="meter mt-2"><span style="width:<%= (weight*100).toFixed(1) %>%;background:<%= p.accent %>"></span></div>
      <div class="flex justify-between mt-2">
        <div><div class="tiny text-muted">Value</div><div class="mono"><%= money.formatCents0(p.value_cents) %></div></div>
        <div class="text-center"><div class="tiny text-muted">Principal</div><div class="mono"><%= money.formatCents0(p.principal_cents) %></div></div>
        <div class="text-right"><div class="tiny text-muted">Investors</div><div class="mono"><%= p.investors %> · <%= p.positions %> pos</div></div>
      </div>
      <div class="tiny text-muted mt-2"><%= p.risk_profile %> · target <%= p.target_low_pct %>–<%= p.target_high_pct %>% p.a. · <%= (weight*100).toFixed(1) %>% of AUM</div>
    </div>
  <% }) %>
</div>

<!-- Positions ledger -->
<div class="flex justify-between items-center mt-3 mb-2 wrap gap-sm">
  <h3 class="mb-0">All positions</h3>
  <div class="seg">
    <a href="/admin/investments" class="<%= status===''?'active':'' %>">All</a>
    <a href="/admin/investments?status=active" class="<%= status==='active'?'active':'' %>">Active</a>
    <a href="/admin/investments?status=withdrawn" class="<%= status==='withdrawn'?'active':'' %>">Withdrawn</a>
  </div>
</div>

<div class="card" style="overflow-x:auto">
  <table class="table">
    <thead><tr><th>Client</th><th>Pool</th><th class="text-right">Principal</th><th class="text-right">Value</th><th class="text-right">Return</th><th>Deposited</th><th>Unlocks</th><th>Status</th></tr></thead>
    <tbody>
      <% if (!positions.length) { %><tr><td colspan="8" class="text-muted text-center" style="padding:24px">No positions.</td></tr><% } %>
      <% positions.forEach(function(p){
           var gain = p.value_cents - p.principal_cents;
           var gainPct = p.principal_cents ? gain / p.principal_cents : 0; %>
        <tr>
          <td class="small"><a href="/admin/clients/<%= p.user_id %>"><%= p.user_name || p.user_email %></a></td>
          <td><span class="legend-item"><span class="swatch" style="background:<%= p.accent %>"></span><%= p.pool_name %></span></td>
          <td class="text-right num"><%= money.formatCents(p.principal_cents) %></td>
          <td class="text-right num"><%= money.formatCents(p.value_cents) %></td>
          <td class="text-right num <%= gain>=0?'text-up':'text-down' %>"><%= money.formatPct(gainPct) %></td>
          <td class="small text-muted"><%= time.formatDate(p.deposited_at) %></td>
          <td class="small text-muted"><%= time.formatDate(p.lock_end_at) %></td>
          <td><span class="pill <%= p.status==='active'?'pill-up':'pill' %>" style="padding:2px 9px"><%= p.status %></span></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/admin-pager', { page: page, pages: pages, base: '/admin/investments?status=' + encodeURIComponent(status) + '&' }) %>

<%- include('../partials/portal-foot') %>
