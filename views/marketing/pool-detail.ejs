<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section>
  <div class="container">
    <a href="/pools" class="small">← All pools</a>
    <div class="flex justify-between items-end wrap gap mt-2 mb-3">
      <div>
        <div class="flex items-center gap-sm mb-1">
          <span class="swatch" style="width:16px;height:16px;border-radius:5px;background:<%= pool.accent %>"></span>
          <span class="eyebrow" style="margin:0;color:<%= pool.accent %>"><%= pool.risk_profile %> risk</span>
        </div>
        <h1 class="mb-0"><%= pool.name %></h1>
      </div>
      <a href="/register" class="btn btn-primary">Invest in this pool →</a>
    </div>

    <div class="card card-pad">
      <div class="flex justify-between items-center wrap gap mb-2">
        <div>
          <div class="tiny text-muted" style="text-transform:uppercase;letter-spacing:.12em">Simulated index · last 12 months</div>
          <div style="font-family:var(--font-serif);font-size:1.6rem">Base 100 →
            <span class="mono" style="color:<%= pool.accent %>"><%= chart.points[chart.points.length-1].toFixed(1) %></span>
          </div>
        </div>
        <span class="pill" style="color:<%= pool.accent %>;border-color:<%= pool.accent %>55"><span class="dot"></span>Target <%= pool.target_low_pct %>–<%= pool.target_high_pct %>% / yr</span>
      </div>
      <canvas class="chart" data-render="line" data-src="detail-chart" style="height:260px"></canvas>
    </div>

    <div class="grid grid-2 mt-3" style="align-items:start">
      <div class="card card-pad">
        <h3>About this pool</h3>
        <p><%= pool.description %></p>
        <hr class="divider" />
        <h3>Risk profile</h3>
        <p>Classified <strong class="risk-<%= pool.risk_profile.split(' ')[0] %>"><%= pool.risk_profile %></strong>. Modelled daily volatility of <span class="mono"><%= (pool.vol_daily*100).toFixed(2) %>%</span> with an expected daily drift of <span class="mono"><%= (pool.drift_daily*100).toFixed(3) %>%</span><% if (pool.jump_prob>0){ %>, plus occasional upward event jumps<% } %>.</p>
      </div>
      <div class="card card-pad">
        <h3>Characteristics</h3>
        <table class="table">
          <tbody>
            <tr><td class="text-muted">Asset class</td><td class="text-right"><%= pool.name %></td></tr>
            <tr><td class="text-muted">Risk rating</td><td class="text-right risk-<%= pool.risk_profile.split(' ')[0] %>"><%= pool.risk_profile %></td></tr>
            <tr><td class="text-muted">Illustrative target</td><td class="text-right mono" style="color:<%= pool.accent %>"><%= pool.target_low_pct %>–<%= pool.target_high_pct %>%</td></tr>
            <tr><td class="text-muted">Daily volatility</td><td class="text-right mono"><%= (pool.vol_daily*100).toFixed(2) %>%</td></tr>
            <tr><td class="text-muted">Lock term</td><td class="text-right"><%= terms.lockYears %> years</td></tr>
            <tr><td class="text-muted">Minimum (blended)</td><td class="text-right mono"><%= money.formatCents0(terms.minDeposit*100) %></td></tr>
          </tbody>
        </table>
        <p class="tiny text-muted mt-2">All figures are illustrative and generated by a simulation engine. Nothing here is a forecast or guarantee.</p>
      </div>
    </div>
  </div>
</section>

<script type="application/json" id="detail-chart"><%- JSON.stringify({ color: pool.accent, axis: true, points: chart.points }) %></script>
<%- include('../partials/footer', { scripts: ['/js/charts.js'] }) %>
