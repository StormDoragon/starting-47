<%- include('../partials/portal-head') %>

<div class="portal-head">
  <div>
    <span class="eyebrow">Investor dashboard</span>
    <h1>Welcome back, <%= currentUser.displayName || 'Investor' %></h1>
  </div>
  <div class="flex gap-sm items-center">
    <span class="pill pill-up"><span class="live-dot"></span> Live · updates every <%= Math.round(tickIntervalMs/1000) %>s</span>
    <a href="/portal/deposit" class="btn btn-primary btn-sm">+ Deposit</a>
  </div>
</div>

<%- include('../partials/flash') %>

<% if (!snap.hasPositions) { %>
  <div class="card card-pad text-center" style="padding:64px 26px">
    <%- include('../partials/icon', { name: 'wallet', size: 34 }) %>
    <h2 class="mt-2">Your portfolio is empty</h2>
    <p class="lead narrow">Make your first deposit to start a live, simulated portfolio across four managed pools.</p>
    <a href="/portal/deposit" class="btn btn-primary btn-lg mt-1">Fund your account →</a>
  </div>
<% } else { %>

  <!-- KPI row -->
  <div class="kpi-row">
    <div class="card stat">
      <div class="label">Portfolio value</div>
      <div class="value value-flash" data-live="totalValue"><%= money.formatCents(snap.totalValueCents) %></div>
      <div class="sub text-muted"><%= money.formatCents0(snap.totalPrincipalCents) %> principal · <%= snap.allocation.length %> pool<%= snap.allocation.length===1?'':'s' %></div>
    </div>
    <div class="card stat">
      <div class="label">Total return</div>
      <div class="value <%= snap.totalGainCents>=0?'text-up':'text-down' %>" data-live="totalGain"><%= (snap.totalGainCents>=0?'+':'') + money.formatCents(snap.totalGainCents) %></div>
      <div class="sub <%= snap.totalGainCents>=0?'text-up':'text-down' %>" data-live="totalGainPct"><%= money.formatPct(snap.totalGainPct) %></div>
    </div>
    <div class="card stat">
      <div class="label">Available cash</div>
      <div class="value" data-live="cashBalance"><%= money.formatCents(currentUser.cashBalanceCents) %></div>
      <div class="sub text-muted">virtual — withdrawals settle here</div>
    </div>
    <div class="card stat">
      <div class="label">Next unlock</div>
      <% if (countdown) { %>
        <div class="countdown mt-1">
          <div class="count-cell"><div class="n"><%= countdown.years %></div><div class="l">yrs</div></div>
          <div class="count-cell"><div class="n"><%= countdown.months %></div><div class="l">mos</div></div>
          <div class="count-cell"><div class="n"><%= countdown.days %></div><div class="l">days</div></div>
        </div>
        <div class="sub text-muted"><%= time.formatDate(nextUnlock) %></div>
      <% } else { %>
        <div class="value">—</div>
      <% } %>
    </div>
  </div>

  <!-- Main charts -->
  <div class="grid" style="grid-template-columns:1.7fr 1fr;gap:22px;align-items:start">
    <div class="card card-pad">
      <div class="flex justify-between items-center mb-2">
        <h3 class="mb-0">Portfolio performance</h3>
        <span class="tiny text-muted mono">simulated · combined value</span>
      </div>
      <canvas class="chart" data-dash-combined style="height:280px" role="img" aria-label="Combined portfolio value over time, simulated, updates live"></canvas>
    </div>

    <div class="card card-pad">
      <h3 class="mb-2">Allocation</h3>
      <div class="donut-wrap">
        <div style="width:170px;flex:none">
          <canvas data-dash-donut style="width:100%;height:170px" role="img" aria-label="Allocation by pool, weights listed beside the chart"></canvas>
        </div>
        <div style="flex:1;min-width:0" data-dash-legend>
          <% snap.allocation.forEach(function(a){ %>
            <div class="flex justify-between items-center legend-row">
              <span class="legend-item"><span class="swatch" style="background:<%= a.accent %>"></span><%= a.name %></span>
              <span class="mono small"><%= (a.weight*100).toFixed(1) %>%</span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>

  <!-- Per-pool positions -->
  <h3 class="mt-3 mb-2">Positions by pool</h3>
  <div class="grid grid-2">
    <% snap.allocation.forEach(function(a){ %>
      <div class="card card-pad">
        <div class="flex justify-between items-center">
          <span class="legend-item"><span class="swatch" style="background:<%= a.accent %>"></span><strong><%= a.name %></strong></span>
          <span class="pill <%= a.gainCents>=0?'pill-up':'pill-down' %>"><span class="dot"></span><%= money.formatPct(a.gainPct) %></span>
        </div>
        <canvas class="spark mt-2" data-dash-pool="<%= a.poolId %>" data-accent="<%= a.accent %>" role="img" aria-label="<%= a.name %> value trend, simulated"></canvas>
        <div class="flex justify-between mt-2">
          <div>
            <div class="tiny text-muted">Value</div>
            <div class="mono" data-live-pool-value="<%= a.poolId %>"><%= money.formatCents(a.valueCents) %></div>
          </div>
          <div class="text-right">
            <div class="tiny text-muted">Principal</div>
            <div class="mono"><%= money.formatCents(a.principalCents) %></div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Transactions -->
  <h3 class="mt-3 mb-2">Recent activity</h3>
  <div class="card" style="overflow:hidden">
    <table class="table">
      <thead><tr><th>Type</th><th>Detail</th><th class="text-right">Amount</th><th>Status</th><th class="text-right">Date</th></tr></thead>
      <tbody>
        <% if (!transactions.length) { %>
          <tr><td colspan="5" class="text-muted text-center" style="padding:24px">No transactions yet.</td></tr>
        <% } %>
        <% transactions.forEach(function(t){
             var label = t.type==='deposit'?'Deposit':(t.type==='withdrawal'?'Withdrawal':'Withdrawal request');
             var cls = t.type==='deposit'?'pill-up':(t.status==='pending'?'pill-info':'pill');
             var detail = t.meta ? (t.meta.pool ? t.meta.pool : (t.meta.early ? 'Early ('+Math.round(t.meta.penaltyPct*100)+'% penalty)' : (t.meta.mature?'Matured':'—'))) : '—';
             var mSign = t.type==='deposit' ? '' : '−'; %>
          <tr>
            <td><span class="pill <%= cls %>"><span class="dot"></span><%= label %></span></td>
            <td class="text-muted small"><%= detail %><% if (t.meta && t.meta.method) { %> · <%= t.meta.method %><% } %></td>
            <td class="text-right num"><%= mSign + money.formatCents(t.amount_cents) %></td>
            <td><span class="small <%= t.status==='completed'?'text-up':(t.status==='pending'?'text-muted':'text-down') %>"><%= t.status %></span></td>
            <td class="text-right small text-muted"><%= time.formatDateTime(t.created_at) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <script type="application/json" id="dash-init"><%- JSON.stringify({ tickIntervalMs: tickIntervalMs }) %></script>
<% } %>

<%- include('../partials/portal-foot', { scripts: snap.hasPositions ? ['/js/charts.js', '/js/dashboard.js'] : [] }) %>
