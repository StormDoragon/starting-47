<%- include('../partials/portal-head') %>

<div class="portal-head">
  <div>
    <span class="eyebrow">Withdrawals</span>
    <h1>Withdraw funds</h1>
  </div>
  <a href="/portal" class="btn btn-ghost btn-sm">← Back to dashboard</a>
</div>

<%- include('../partials/flash') %>

<% if (!positions.length) { %>
  <div class="card card-pad text-center" style="padding:56px 26px">
    <%- include('../partials/icon', { name: 'arrowDown', size: 32 }) %>
    <h2 class="mt-2">No active positions</h2>
    <p class="lead">Once you fund your account, your positions and their maturity dates will appear here.</p>
    <a href="/portal/deposit" class="btn btn-primary mt-1">Make a deposit →</a>
  </div>
<% } else { %>

  <p class="small text-muted mb-3">Positions are locked for <%= terms.lockYears %> years. Withdrawing before maturity applies a penalty, shown below and confirmed before any request. All withdrawals are simulated — no real payout occurs.</p>

  <div class="grid grid-2">
    <% positions.forEach(function(item){
         var p = item.pos, pool = item.pool, pv = item.preview, cd = item.countdown; %>
      <div class="card card-pad">
        <div class="flex justify-between items-center">
          <span class="legend-item"><span class="swatch" style="background:<%= pool.accent %>"></span><strong><%= pool.name %></strong></span>
          <% if (pv.mature) { %>
            <span class="pill pill-up"><span class="dot"></span>Matured</span>
          <% } else { %>
            <span class="pill pill-info"><span class="dot"></span>Locked · <%= cd.years %>y <%= cd.months %>m <%= cd.days %>d left</span>
          <% } %>
        </div>

        <div class="grid grid-2 mt-2" style="gap:14px">
          <div><div class="tiny text-muted">Current value</div><div class="mono" style="font-size:1.2rem"><%= money.formatCents(pv.valueCents) %></div></div>
          <div class="text-right"><div class="tiny text-muted">Principal</div><div class="mono"><%= money.formatCents(p.principal_cents) %></div></div>
          <div><div class="tiny text-muted">Deposited</div><div class="small"><%= time.formatDate(p.deposited_at) %></div></div>
          <div class="text-right"><div class="tiny text-muted">Unlocks</div><div class="small"><%= time.formatDate(p.lock_end_at) %></div></div>
        </div>

        <hr class="divider" />

        <% if (pv.mature) { %>
          <div class="flex justify-between items-center mb-2">
            <span class="text-muted small">Withdrawable now</span>
            <span class="mono text-up" style="font-size:1.1rem"><%= money.formatCents(pv.netCents) %></span>
          </div>
          <form method="post" action="/portal/withdraw/<%= p.id %>">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn btn-primary btn-block" type="submit">Withdraw <%= money.formatCents(pv.netCents) %></button>
          </form>
        <% } else { %>
          <div class="card" style="background:var(--down-soft);border-color:rgba(240,115,107,0.3);padding:14px;margin-bottom:14px">
            <div class="flex justify-between small"><span>Early-withdrawal penalty (<%= pv.tierLabel %>)</span><span class="mono text-down"><%= (pv.penaltyPct*100).toFixed(0) %>%</span></div>
            <div class="flex justify-between small mt-1"><span class="text-muted">Penalty amount</span><span class="mono text-down">−<%= money.formatCents(pv.penaltyCents) %></span></div>
            <div class="flex justify-between mt-1" style="border-top:1px solid var(--line);padding-top:8px"><span>Net you would receive</span><span class="mono"><%= money.formatCents(pv.netCents) %></span></div>
          </div>
          <form method="post" action="/portal/withdraw/<%= p.id %>" data-confirm="Confirm early withdrawal? A <%= (pv.penaltyPct*100).toFixed(0) %>% penalty (<%= money.formatCents(pv.penaltyCents) %>) will be applied. This is simulated — no real payout occurs.">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label class="choice-body" style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;margin-bottom:12px">
              <input type="checkbox" name="confirm_penalty" value="yes" required style="margin-top:3px" />
              <span class="small">I understand this is an early withdrawal, a <strong class="text-down"><%= (pv.penaltyPct*100).toFixed(0) %>%</strong> penalty applies, and the request is simulated.</span>
            </label>
            <button class="btn btn-danger btn-block" type="submit">Request early withdrawal</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/portal-foot') %>
